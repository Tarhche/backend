WEB_URL=http://localhost:3000

# storage
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minio-access-key
S3_SECRET_KEY=minio-secret-key
S3_BUCKET_NAME=blog
S3_USE_SSL=false

# database
MONGO_SCHEME=mongodb
MONGO_USERNAME=test
MONGO_PASSWORD=test
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE_NAME=blog

# mail
MAIL_SMTP_FROM=no-reply@localhost
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_HOST=mailserver
MAIL_SMTP_PORT=1025

# messaging
NATS_URL=nats:4222

# runner
BACKEND_DOCKER_HOST=tcp://docker:2375

# OpenTelemetry / local Grafana (grafana/otel-lgtm, see compose.yaml "grafana"
# service) - traces, logs and metrics all go here and show up in Grafana at
# http://localhost:3001 (admin/admin).
# To go back to Grafana Cloud: endpoint https://otlp-gateway-prod-eu-west-2.grafana.net/otlp,
# insecure=false, and restore OTEL_EXPORTER_OTLP_HEADERS with your Grafana Cloud API key
# (not stored here - fetch it from Grafana Cloud > Connections > OpenTelemetry).
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_RESOURCE_ATTRIBUTES="deployment.environment=development"
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana:4318
OTEL_EXPORTER_OTLP_HEADERS=

# Continuous profiling
PROFILING_ENABLED=true
